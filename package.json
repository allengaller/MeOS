{
  "name": "meos",
  "version": "0.1.0",
  "description": "人生管理系统 - 基于反思与梳理的多方法论生活管理平台",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "backend:dev": "pnpm --filter @meos/api dev",
    "web:dev": "pnpm --filter @meos/web dev",
    "web:build:extension": "pnpm --filter @meos/web build:extension"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@meos/shared": "workspace:^",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/ui": "^1.6.1",
    "esbuild": "0.21.5",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "object-hash": "^3.0.0",
    "prettier": "^3.8.3",
    "turbo": "^1.11.3",
    "vitest": "^1.1.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "pnpm": {
    "overrides": {
      "esbuild": "0.21.5"
    }
  },
  "dependencies": {
    "axios": "^1.13.2",
    "lucide-react": "^0.562.0"
  }
}
